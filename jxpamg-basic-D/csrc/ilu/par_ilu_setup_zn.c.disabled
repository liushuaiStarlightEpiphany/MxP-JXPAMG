//     /* Allocate matrices */
//     D_data = jx_TAlloc(JX_Real, n);
//     D1_data = jx_TAlloc(JX_Real, n);
//     d_data = jx_TAlloc(JX_Real, n);
//     d1_data = jx_TAlloc(JX_Real, n);
//     L_diag_i = jx_TAlloc(JX_Int, n + 1);
//     U_diag_i = jx_TAlloc(JX_Int, n + 1);
