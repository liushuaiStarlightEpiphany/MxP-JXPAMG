//     L_diag_data = jx_TAlloc(JX_Real, L_nnz);
//     U_diag_j = jx_TAlloc(JX_Int, U_nnz);
//     U_diag_data = jx_TAlloc(JX_Real, U_nnz);
//     L1_diag_data = jx_TAlloc(JX_Real, L_nnz);
