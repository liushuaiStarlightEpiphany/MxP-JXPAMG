//     ROW_OMP = (n + nt - 1) / nt;

//     /* Allocate workL and workU for non-zero prefix sums */
//     workL = jx_TAlloc(JX_Int, nt + 1);
//     workU = jx_TAlloc(JX_Int, nt + 1);
//     if (!workL || !workU)
//     {
//         printf("Error: Memory allocation failed for workL or workU\n");
//         jx_TFree(workL);
