#include "jx_parilu.h"
#include "jx_krylov.h"

/*--------------------------------------------------------------------------
 * JX_ILUCreate
 *--------------------------------------------------------------------------*/

JX_Int
JX_ILUCreate(JX_Solver *solver)
{
   if (!solver)
   {
      jx_error_in_arg(2);
      return jx_error_flag;
   }
   *solver = ((JX_Solver)jx_ILUCreate());
   return jx_error_flag;
}

/*--------------------------------------------------------------------------
 * JX_ILUDestroy
 *--------------------------------------------------------------------------*/

JX_Int
JX_ILUDestroy(JX_Solver solver)
{
   return (jx_ILUDestroy((void *)solver));
}

/*--------------------------------------------------------------------------
 * JX_ILUSetup
 *--------------------------------------------------------------------------*/

JX_Int
JX_ILUSetup(JX_Solver solver,
            JX_ParCSRMatrix A,
            JX_ParVector b,
            JX_ParVector x)
{
   return (jx_ILUSetup((void *)solver,
                       (jx_ParCSRMatrix *)A,
                       (jx_ParVector *)b,
                       (jx_ParVector *)x));
}

/*--------------------------------------------------------------------------
 * JX_ILUSolve
 *--------------------------------------------------------------------------*/

JX_Int
JX_ILUSolve(JX_Solver solver,
            JX_ParCSRMatrix A,
            JX_ParVector b,
            JX_ParVector x)
{
   return (jx_ILUSolve((void *)solver,
                       (jx_ParCSRMatrix *)A,
                       (jx_ParVector *)b,
                       (jx_ParVector *)x));
}

